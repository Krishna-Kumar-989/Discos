# Qdrant Database Connection
# Set these variables to connect to an external hosted Qdrant instance (like Qdrant Cloud)
# or a local central instance (like a Docker container).

# For local docker: http://localhost:6333
# For Qdrant cloud: https://<cluster-id>.cloud.qdrant.io:6333
QDRANT_URL=""

# Your Qdrant API Key (leave empty for local unauthenticated instances)
QDRANT_API_KEY=""
