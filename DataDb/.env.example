
#sqlite, postgres, mysql, mongodb
DB_PROVIDER=sqlite

# SQLite Settings
SQLITE_DB_PATH=DataDb/data.db

# PostgreSQL Settings 
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
