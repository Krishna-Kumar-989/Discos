# MySQL Settings 
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=discos

# MongoDB Settings 
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=discos
